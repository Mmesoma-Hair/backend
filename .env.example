# --- Django ---------------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database (Postgres) ---------------------------------------------------
POSTGRES_DB=idealcommerce
POSTGRES_USER=idealcommerce
POSTGRES_PASSWORD=idealcommerce
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis / Celery --------------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
# Run tasks inline (no worker) when true.
CELERY_TASK_ALWAYS_EAGER=false

# --- CORS ------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Auth / JWT ------------------------------------------------------------
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7
# Used to build password-reset links in emails, and for transactional senders.
FRONTEND_BASE_URL=http://localhost:3000
DEFAULT_FROM_EMAIL=no-reply@idealcommerce.test

# --- Cloudinary (product image storage/CDN) -------------------------------
# Either set CLOUDINARY_URL, or the discrete trio below.
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=idealcommerce/products
# Product-image backend: "cloudinary" (real) or "mock" (no network; default when
# no cloud name is set). Tests always force "mock".
CATALOG_IMAGE_BACKEND=mock

# --- FX rates provider (Phase 4) ------------------------------------------
# One of: mock | currencyapi_net | frankfurter
RATES_PROVIDER=mock
CURRENCY_API_NET_KEY=
# Default Celery Beat cadence for FX refresh (seconds); admins can also tune
# storeconfig `currency.refresh_minutes`.
CURRENCY_REFRESH_SECONDS=3600

# --- Payments (Phase 6) ----------------------------------------------------
# Provider: "mock" (no external account). Stripe/Paystack/Flutterwave plug in later.
PAYMENT_PROVIDER=mock
# Secret used to sign/verify payment webhook payloads.
PAYMENT_WEBHOOK_SECRET=dev-webhook-secret

# --- Notifications (Phase 9) -----------------------------------------------
# Email backend: console | zeptomail | django | memory
NOTIFICATIONS_EMAIL_BACKEND=console
# Telegram backend: console | http | memory | disabled
NOTIFICATIONS_TELEGRAM_BACKEND=console
NOTIFICATIONS_HTTP_TIMEOUT=10

# ZeptoMail (Zoho) transactional email API. NEVER commit the real token — keep it
# in your local .env only (this file is an example).
ZEPTOMAIL_API_URL=https://api.zeptomail.com/v1.1/email
ZEPTOMAIL_TOKEN=

# Sender identity + branding shown in emails.
EMAIL_FROM_ADDRESS=no-reply@idealcommerce.test
EMAIL_FROM_NAME=IdealCommerce
SUPPORT_EMAIL=support@idealcommerce.test
# Absolute URL (required for email clients).
EMAIL_LOGO_URL=http://localhost:3000/logo.png

# Telegram bot. TELEGRAM_DEFAULT_CHAT_ID is the store-ops chat for new-order alerts.
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=
